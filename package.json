{
  "name": "faustmod",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based modular audio synthesis IDE using Faust DSP and rete.js",
  "author": "Andre Paquette",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "npm run catalog",
    "dev": "vite",
    "catalog": "node scripts/build-catalog.mjs",
    "prebuild": "npm run catalog",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@grame/faustwasm": "^0.16.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rete": "^2.0.6",
    "rete-area-plugin": "^2.3.2",
    "rete-comment-plugin": "^2.2.0",
    "rete-connection-plugin": "^2.0.5",
    "rete-history-plugin": "^2.2.0",
    "rete-react-plugin": "^2.1.2",
    "rete-render-utils": "^2.0.3",
    "styled-components": "^6.4.4",
    "webpd": "^1.0.0-alpha.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
